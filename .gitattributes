# Normalize line endings on commit; check out native on the working platform.
* text=auto

# Scripts that MUST remain LF (they run on Linux in CI / Docker).
mvnw            text eol=lf
*.sh            text eol=lf
*.yml           text eol=lf
*.yaml          text eol=lf
Dockerfile      text eol=lf

# Windows scripts must remain CRLF.
mvnw.cmd        text eol=crlf
*.bat           text eol=crlf
*.cmd           text eol=crlf

# Treat the wrapper jar and common binaries as binary.
*.jar           binary
*.png           binary
*.jpg           binary
