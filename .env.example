# Copy to `.env` and adjust for your environment. Never commit the real `.env`.

# --- Database ---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=taskdb
DB_USERNAME=taskuser
DB_PASSWORD=taskpass
DB_ROOT_PASSWORD=rootpass

# --- Security ---
# Base64-encoded HMAC secret, at least 256 bits. Generate one with:
#   openssl rand -base64 48
JWT_SECRET=c3ByaW5nLWJvb3Qtc3RhcnRlci10ZW1wbGF0ZS1kZXYtc2VjcmV0LWNoYW5nZS1tZS1ub3c=
JWT_EXPIRATION_MINUTES=60

# --- App ---
SERVER_PORT=8080
CORS_ALLOWED_ORIGINS=http://localhost:3000
SEED_ENABLED=false
APP_LOG_LEVEL=INFO
